# Copy this file to .env and fill in real values.
# Never commit the real .env file.

# Application
NODE_ENV=development
PORT=3000

# Docker Hub (used only locally if you build/push manually;
# in CI these come from GitHub Actions secrets, never from this file)
DOCKER_USERNAME=your-dockerhub-username
DOCKER_IMAGE_NAME=your-dockerhub-username/github-actions-capstone
